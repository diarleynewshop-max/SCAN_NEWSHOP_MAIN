VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
CLICKUP_TOKEN=
CLICKUP_TOKEN_SF=
CLICKUP_LIST_ID_COMPRAS=
CLICKUP_LIST_ID_COMPRAS_NEWSHOP=
CLICKUP_LIST_ID_COMPRAS_SOYE=
CLICKUP_LIST_ID_COMPRAS_FACIL=
CLICKUP_TODO_LIST_ID_NEWSHOP=
CLICKUP_TODO_LIST_ID_SOYE=
CLICKUP_TODO_LIST_ID_FACIL=
CLICKUP_TODO_LIST_ID_SF=
CLICKUP_RELATORIO_LIST_ID_NEWSHOP=
CLICKUP_RELATORIO_LIST_ID_SOYE=
CLICKUP_RELATORIO_LIST_ID_FACIL=
CLICKUP_RELATORIO_LIST_ID_SF=

# Expedicao Integration (mesma URL, chaves diferentes por loja)
EXPEDICAO_API_KEY=          # chave Newshop
EXPEDICAO_API_KEY_SF=       # chave Soye e Facil

# ERP / Varejo Facil API
# Na Vercel, prefira sem VITE_ para nao expor credenciais no navegador.
ERP_API_USERNAME=
ERP_API_PASSWORD=
ERP_API_TOKEN=
ERP_API_URL_NEWSHOP=https://newshop.varejofacil.com
ERP_API_URL_FACIL=https://facil.varejofacil.com
ERP_API_URL_SOYE=https://soye.varejofacil.com

# Sync de fotos do APP para o ERP (Trigger.dev)
# Habilitar com "true" para que fotos tiradas no app subam para o cadastro do produto no ERP.
ERP_FOTO_SYNC_ENABLED=false

# Análise Automática (Trigger.dev -> /api/clickup-proxy)
# URL pública do app (sem barra no final) usada pelo schedule do Trigger.dev pra chamar o proxy.
APP_BASE_URL=https://seu-app.vercel.app
# Opcional: se definido, o endpoint /api/clickup-proxy?action=executar-analise-automatica
# só aceita chamadas com o header x-cron-secret igual a este valor.
CRON_SECRET=

# Local/dev com Vite. Pode usar geral ou sobrescrever por empresa.
VITE_ERP_API_URL=
VITE_ERP_API_USERNAME=
VITE_ERP_API_PASSWORD=
VITE_ERP_API_TOKEN=
VITE_ERP_API_URL_NEWSHOP=https://newshop.varejofacil.com
VITE_ERP_API_USERNAME_NEWSHOP=
VITE_ERP_API_PASSWORD_NEWSHOP=
VITE_ERP_API_TOKEN_NEWSHOP=
VITE_ERP_API_URL_FACIL=https://facil.varejofacil.com
VITE_ERP_API_USERNAME_FACIL=
VITE_ERP_API_PASSWORD_FACIL=
VITE_ERP_API_TOKEN_FACIL=
VITE_ERP_API_URL_SOYE=https://soye.varejofacil.com
VITE_ERP_API_USERNAME_SOYE=
VITE_ERP_API_PASSWORD_SOYE=
VITE_ERP_API_TOKEN_SOYE=
